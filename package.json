{
  "name": "eat",
  "version": "1.0.0",
  "description": "Household dinner-planning web app (Remix v3 + SQLite)",
  "type": "module",
  "private": true,
  "scripts": {
    "build:css": "cp -r node_modules/@sethmakes/tokens/fonts public/static/ && tailwindcss -i styles/app.css -o public/static/app.css --minify",
    "serve": "npm run build:css && tsx server.ts",
    "dev": "npm run build:css && tsx watch server.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.111",
    "@iconify/tailwind4": "^1.2.3",
    "@sethmakes/css": "^0.1.4",
    "@sethmakes/icons": "^0.1.4",
    "@sethmakes/tokens": "^0.1.4",
    "better-sqlite3": "^11.8.1",
    "remix": "3.0.0-beta.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/cli": "^4.3.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
